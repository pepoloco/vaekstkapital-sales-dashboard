# HubSpot Private App Token (NOT the old API key)
# Create one at: HubSpot → Settings → Integrations → Private Apps
# Required scopes: crm.objects.deals.read, crm.objects.contacts.read,
#                  crm.objects.owners.read, crm.objects.engagements.read
HUBSPOT_ACCESS_TOKEN=pat-na1-REPLACE_ME

# Your HubSpot portal/account ID (visible in the URL when logged in)
HUBSPOT_PORTAL_ID=REPLACE_ME

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_ME
